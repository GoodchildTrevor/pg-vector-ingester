# PostgreSQL async DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dialogue

# fastembed dense model — must match the model used in qdrant-ingester
DENSE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Embedding batch size (messages per fastembed call)
BATCH_SIZE=32

# DB UPDATE batch size (rows per transaction)
INSERT_BATCH_SIZE=64
